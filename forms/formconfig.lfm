          object LabelJsonPointer2: TLabel
            Left = 5
            Height = 240
            Top = 5
            Width = 538
            Align = alTop
            BorderSpacing.Right = 20
            BorderSpacing.Bottom = 5
            BorderSpacing.Around = 5
            Caption = 'Json Pointer: Use / for levels, keys for objects, and numbers for indexes. Use * for all items, *#10 to join items by newline. Use ~ at the end of the path to return the raw JSON branch. Separate multiple segments with semicolon ;.'#13#10'Literal: Text block in {…}. Special tag #10 for newlines. Use {{regex}} inside to extract data directly into the text.'#13#10'Logic: If a Pointer in a segment is empty, the whole segment is skipped. If a segment has no Pointer, only literal text blocks with embedded regular expressions are processed.'#13#10'Regex: {prefix {regex[index]} suffix} inside a text block. If no [index] is specified, the first match is used. Index can be a number, [*] (join by space), or [*#10] (join by newline). If the regex finds no match, the entire {…} block is removed. Using ~ inside a regex returns the entire text.'#13#10'Inversion: Start a segment with ! (e.g. !/path{Error}) to show its text only if the Pointer data is missing or the JSON is invalid.'#13#10'Commenting: /* text */ comments are stripped from the entire expression before any processing.'#13#10'Examples:'#13#10'responseData/translatedText; matches/*#10/translation; /texts/text; {literal text#10}; /result/text; /text{ ({(\w+)})}; !/translations{Error: No data!#10}; /translations/0/text'
            Color = clInfoBk
            ParentColor = False
            Transparent = False
            WordWrap = True
          end
